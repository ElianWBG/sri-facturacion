# Copia este archivo a .env y rellena los valores reales

# Django
SECRET_KEY=cambia-esto-por-una-clave-segura
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=sri_facturacion
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Redis (broker de Celery)
REDIS_URL=redis://localhost:6379/0

# Directorio donde se guardan XMLs y PDFs por contribuyente
COMPROBANTES_DIR=/app/comprobantes

# Email (para enviar comprobantes autorizados al cliente)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SG.xxxxxxxxxxxx
DEFAULT_FROM_EMAIL=facturacion@tudominio.com
